 "segments": [
  {
   "start": 10.7,
   "end": 12.1,
   "text": "Vocalist 渡辺孝敏"
  },
  {
   "start": 31.7,
   "end": 37.7,
   "text": "君とのラブストーリー それは予想通り"
  },
  {
   "start": 37.7,
   "end": 41.7,
   "text": "いざ始まれば一人芝居だ"
  },
  {
   "start": 41.7,
   "end": 44.4,
   "text": "ずっとそばにいたって"
  },
  {
   "start": 44.4,
   "end": 47.5,
   "text": "結局ただの観客だ"
  },
  {
   "start": 47.5,
   "end": 50.5,
   "text": "感情のないI'm sorry"
  },
  {
   "start": 50.5,
   "end": 53.4,
   "text": "それはいつも通り"
  },
  {
   "start": 53.4,
   "end": 55.3,
   "text": "慣れてしまえば"
  },
  {
   "start": 55.3,
   "end": 57.3,
   "text": "悪くはないけど"
  },
  {
   "start": 57.3,
   "end": 61.0,
   "text": "君とのロマンスは人生から"
  },
  {
   "start": 61.0,
   "end": 65.7,
   "text": "続きはしないことを知った"
  },
  {
   "start": 67.7,
   "end": 73.1,
   "text": "もっと違う設定で もっと違う関係で"
  },
  {
   "start": 73.1,
   "end": 78.2,
   "text": "出会える世界線 選べたらよかった"
  },
  {
   "start": 78.2,
   "end": 83.6,
   "text": "もっと違う性格で もっと違う価値観で"
  },
  {
   "start": 83.6,
   "end": 88.2,
   "text": "愛を伝えられたらいいね"
  },
  {
   "start": 88.2,
   "end": 92.6,
   "text": "そう願っても無駄だから"
  },
  {
   "start": 92.6,
   "end": 98.9,
   "text": "Goodbye 君の運命の人は僕じゃない"
  },
  {
   "start": 98.9,
   "end": 104.6,
   "text": "辛いけど否めない でも離れがたいのさ"
  },
  {
   "start": 105.5,
   "end": 111.5,
   "text": "その紙に触れただけで痛いやいや"
  },
  {
   "start": 111.5,
   "end": 114.4,
   "text": "でも甘いないやいや"
  },
  {
   "start": 114.4,
   "end": 119.8,
   "text": "Goodbye それじゃ僕にとって君は何?"
  },
  {
   "start": 119.8,
   "end": 126.4,
   "text": "答えは分からない わかりたくもないのさ"
  },
  {
   "start": 126.4,
   "end": 134.2,
   "text": "たったひとつ 確かなことがあるとするのならば"
  },
  {
   "start": 134.2,
   "end": 140.5,
   "text": "君は綺麗だ"
  },
  {
   "start": 141.2,
   "end": 147.2,
   "text": "誰かが偉そうに 語る恋愛の論理"
  },
  {
   "start": 147.2,
   "end": 151.4,
   "text": "何一つとして ピンとこなくて"
  },
  {
   "start": 151.4,
   "end": 154.9,
   "text": "飛行機の窓から見下ろした"
  },
  {
   "start": 154.9,
   "end": 159.7,
   "text": "知らない街の夜景みたいだ"
  },
  {
   "start": 161.9,
   "end": 167.1,
   "text": "もっと違う選定で もっと違う関係で"
  },
  {
   "start": 167.1,
   "end": 172.1,
   "text": "出会える世界線 選べたらよかった"
  },
  {
   "start": 172.1,
   "end": 177.2,
   "text": "至って純な心で 叶った恋を抱きしめて"
  },
  {
   "start": 177.2,
   "end": 182.0,
   "text": "好きだとか無責任に言えたらいいね"
  },
  {
   "start": 182.0,
   "end": 187.3,
   "text": "そう願っても虚しいのさ"
  },
  {
   "start": 187.3,
   "end": 193.1,
   "text": "Goodbye 繋いだ手の向こうにアンドライン"
  },
  {
   "start": 193.1,
   "end": 199.1,
   "text": "引き伸ばす度に 疼き出す未来には"
  },
  {
   "start": 199.1,
   "end": 204.6,
   "text": "君はいない その事実に Cry"
  },
  {
   "start": 206.3,
   "end": 210.9,
   "text": "そりゃ苦しいよな"
  },
  {
   "start": 229.1,
   "end": 234.6,
   "text": "Goodbye 君の運命の人は僕じゃない"
  },
  {
   "start": 234.6,
   "end": 241.2,
   "text": "辛いけど否めない でも離れがたいのさ"
  },
  {
   "start": 241.2,
   "end": 249.8,
   "text": "その髪に触れただけで痛いや でも甘いないや"
  },
  {
   "start": 249.8,
   "end": 255.5,
   "text": "Goodbye それじゃ僕にとって君は何?"
  },
  {
   "start": 255.5,
   "end": 262.0,
   "text": "答えは分からない わかりたくもないのさ"
  },
  {
   "start": 262.0,
   "end": 269.9,
   "text": "たったひとつ 確かなことがあるとするのならば"
  },
  {
   "start": 269.9,
   "end": 272.2,
   "text": "君は綺麗だ"
  },
  {
   "start": 272.2,
   "end": 280.5,
   "text": "これも これも ロマンスの定めなら"
  },
  {
   "start": 280.5,
   "end": 282.7,
   "text": "悪くないよな"
  },
  {
   "start": 282.7,
   "end": 289.9,
   "text": "永遠とは思わないけど"
  },
  {
   "start": 290.7,
   "end": 295.5,
   "text": "とても綺麗だ"
  }
 ],
